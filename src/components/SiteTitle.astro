---
const { siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title sl-flex" translate="no">
	<svg
		class="site-title__mark"
		xmlns="http://www.w3.org/2000/svg"
		viewBox="0 0 128 128"
		role="img"
		aria-label="BacklogHQ mark"
	>
		<path
			fill-rule="evenodd"
			d="M81 36 64 0 47 36l-1 2-9-10a6 6 0 0 0-9 9l10 10h-2L0 64l36 17h2L28 91a6 6 0 1 0 9 9l9-10 1 2 17 36 17-36v-2l9 10a6 6 0 1 0 9-9l-9-9 2-1 36-17-36-17-2-1 9-9a6 6 0 1 0-9-9l-9 10v-2Zm-17 2-2 5c-4 8-11 15-19 19l-5 2 5 2c8 4 15 11 19 19l2 5 2-5c4-8 11-15 19-19l5-2-5-2c-8-4-15-11-19-19l-2-5Z"
			clip-rule="evenodd"></path>
		<path
			d="M118 19a6 6 0 0 0-9-9l-3 3a6 6 0 1 0 9 9l3-3Zm-96 4c-2 2-6 2-9 0l-3-3a6 6 0 1 1 9-9l3 3c3 2 3 6 0 9Zm0 82c-2-2-6-2-9 0l-3 3a6 6 0 1 0 9 9l3-3c3-2 3-6 0-9Zm96 4a6 6 0 0 1-9 9l-3-3a6 6 0 1 1 9-9l3 3Z"
		></path>
	</svg>
	<span class="site-title__wordmark">
		backlog<span class="site-title__hq">hq</span>
	</span>
</a>

<style>
	.site-title {
		align-items: center;
		gap: 10px;
		text-decoration: none;
		white-space: nowrap;
		min-width: 0;
		color: var(--sl-color-text);
	}
	.site-title__mark {
		width: 22px;
		height: 22px;
		flex-shrink: 0;
		fill: currentColor;
	}
	.site-title__wordmark {
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: 17px;
		letter-spacing: -0.02em;
		color: var(--sl-color-text);
		overflow: hidden;
	}
	.site-title__hq {
		font-family: var(--font-mono);
		font-weight: 700;
		color: var(--sl-color-accent);
		letter-spacing: -0.02em;
	}
</style>
